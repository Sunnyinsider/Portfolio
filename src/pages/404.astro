---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts";
---

<Layout title={SITE.TITLE} description={SITE.DESCRIPTION}>
    <main class="min-h-screen flex items-center flex-col gap-4 justify-center">
        <h1 class="heading text-4xl uppercase">Error 404</h1>
        <p class="text-secondary">
            I've gotten rid of this page, sorry! Or it just never existed? Either way:
        </p>
        <a href="/" class="cursor-pointer underline">&larr; Head on back!</a>
    </main>
</Layout>
